---
---
<header class="fixed top-0 left-0 right-0 z-50 bg-slate-950/80 backdrop-blur border-b border-white/10">
  <nav class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">

    <a href="#" class="text-xl font-semibold tracking-wide">
      Royal <span class="text-sky-400">Splash</span>
    </a>

    <!-- Links (visíveis só no desktop) -->
    <div class="hidden md:flex items-center gap-8 text-sm text-slate-300">
      <a href="#servicos" class="hover:text-white transition-colors">Serviços</a>
      <a href="#portfolio" class="hover:text-white transition-colors">Portfólio</a>
      <a href="#contato" class="hover:text-white transition-colors">Contato</a>
    </div>

    <!-- Botão Orçamento (visível só no desktop) -->
    <a href="#contato" class="hidden md:inline-block bg-sky-500 hover:bg-sky-400 text-white text-sm font-medium px-5 py-2.5 rounded-full transition-colors">
      Orçamento
    </a>

    <!-- Botão hambúrguer (visível só no celular) -->
    <button id="menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Abrir menu">
      <span class="w-6 h-0.5 bg-white"></span>
      <span class="w-6 h-0.5 bg-white"></span>
      <span class="w-6 h-0.5 bg-white"></span>
    </button>

  </nav>

  <!-- Menu que abre no celular -->
  <div id="mobile-menu" class="hidden md:hidden bg-slate-950 border-t border-white/10 px-6 py-6 flex-col gap-4 text-slate-300">
    <a href="#servicos" class="block py-2 hover:text-white transition-colors">Serviços</a>
    <a href="#portfolio" class="block py-2 hover:text-white transition-colors">Portfólio</a>
    <a href="#contato" class="block py-2 hover:text-white transition-colors">Contato</a>
    <a href="#contato" class="block mt-2 bg-sky-500 hover:bg-sky-400 text-white text-center font-medium px-5 py-3 rounded-full transition-colors">Orçamento</a>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });

  // Fecha o menu ao clicar em qualquer link
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
    });
  });
</script>