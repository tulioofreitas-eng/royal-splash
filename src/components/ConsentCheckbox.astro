---
// Componente reutilizável do checkbox de consentimento LGPD.
// Importe em qualquer formulário e coloque logo ACIMA do botão de envio.
// O `required` bloqueia o envio sem o consentimento.
---
<label class="flex items-start gap-2 text-sm text-slate-400 leading-snug mb-4 cursor-pointer">
  <input
    type="checkbox"
    name="consentimento"
    required
    class="mt-1 w-4 h-4 accent-piscina cursor-pointer shrink-0"
  />
 <span>
  Concordo com o uso dos meus dados para contato, conforme a{' '}
  <a href="/politica-de-privacidade" target="_blank" rel="noopener noreferrer" class="text-piscina hover:opacity-80 underline">
    Política de Privacidade
  </a>{' '}
  da Royal Splash.
</span>
</label>