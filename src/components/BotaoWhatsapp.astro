<button
  type="button"
  id="btn-abrir-whatsapp"
  aria-label="Falar no WhatsApp"
  style="position:fixed; bottom:24px; right:24px; z-index:9999; display:inline-flex; align-items:center; gap:8px; background:#22c55e; color:#fff; font-weight:600; padding:14px 22px; border-radius:9999px; box-shadow:0 4px 16px rgba(0,0,0,0.4); border:none; cursor:pointer;"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.372-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05.088C5.495.088.088 5.495.085 12.05a11.86 11.86 0 001.588 5.945L.088 23.911l5.938-1.557a11.89 11.89 0 005.694 1.451h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.483-8.413z"/></svg>
  <span>WhatsApp</span>
</button>

<div id="whatsapp-modal" style="display:none; position:fixed; inset:0; z-index:10000; background:rgba(0,0,0,0.7); align-items:center; justify-content:center; padding:16px;">
  <div style="background:#0B1D2E; border:1px solid rgba(255,255,255,0.15); border-radius:16px; padding:24px; max-width:400px; width:100%;">
    <h3 style="color:#fff; font-size:1.25rem; font-weight:600; margin-bottom:16px;">Antes de conversar...</h3>
    <div style="margin-bottom:12px;">
      <label style="display:block; font-size:0.85rem; color:#94a3b8; margin-bottom:4px;">Nome</label>
      <input type="text" id="wa-nome" style="width:100%; background:#0B1D2E; border:1px solid rgba(255,255,255,0.15); border-radius:8px; padding:10px 14px; color:#fff;" placeholder="Seu nome" />
    </div>
    <div style="margin-bottom:12px;">
      <label style="display:block; font-size:0.85rem; color:#94a3b8; margin-bottom:4px;">Telefone</label>
      <input type="tel" id="wa-telefone" style="width:100%; background:#0B1D2E; border:1px solid rgba(255,255,255,0.15); border-radius:8px; padding:10px 14px; color:#fff;" placeholder="(00) 00000-0000" />
    </div>
    <div style="margin-bottom:20px;">
      <label style="display:block; font-size:0.85rem; color:#94a3b8; margin-bottom:4px;">Tipo de projeto</label>
      <select id="wa-tipo" style="width:100%; background:#0B1D2E; border:1px solid rgba(255,255,255,0.15); border-radius:8px; padding:10px 14px; color:#fff;">
        <option value="">Selecione...</option>
        <option value="Construção de piscina">Construção de piscina</option>
        <option value="Área de lazer">Área de lazer</option>
        <option value="Sauna / Spa">Sauna / Spa</option>
        <option value="Reforma / Revitalização">Reforma / Revitalização</option>
        <option value="Detecção de vazamento">Detecção de vazamento</option>
        <option value="Piscina de fibra">Piscina de fibra</option>
        <option value="Projeto corporativo">Projeto corporativo</option>
        <option value="Outro">Outro</option>
      </select>
    </div>
    <div style="display:flex; gap:10px;">
      <button type="button" id="wa-cancelar" style="flex:1; background:transparent; border:1px solid rgba(255,255,255,0.2); color:#94a3b8; padding:12px; border-radius:9999px; cursor:pointer;">Cancelar</button>
      <button type="button" id="wa-enviar" style="flex:2; background:#22c55e; border:none; color:#fff; font-weight:600; padding:12px; border-radius:9999px; cursor:pointer;">Continuar no WhatsApp</button>
    </div>
  </div>
</div>

<script>
  const botoesAbrir = document.querySelectorAll('#btn-abrir-whatsapp, .abrir-whatsapp-modal');
  const modal = document.getElementById('whatsapp-modal')!;
  const btnCancelar = document.getElementById('wa-cancelar')!;
  const btnEnviar = document.getElementById('wa-enviar')!;

  botoesAbrir.forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      modal.style.display = 'flex';
    });
  });

  btnCancelar.addEventListener('click', () => {
    modal.style.display = 'none';
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.style.display = 'none';
  });

  btnEnviar.addEventListener('click', () => {
    const nome = (document.getElementById('wa-nome') as HTMLInputElement).value.trim();
    const telefone = (document.getElementById('wa-telefone') as HTMLInputElement).value.trim();
    const tipo = (document.getElementById('wa-tipo') as HTMLSelectElement).value;

    if (!nome || !telefone) {
      alert('Por favor, preencha nome e telefone.');
      return;
    }

    const mensagem = `Olá! Me chamo ${nome} (${telefone}). Tenho interesse em: ${tipo || 'um orçamento'}.`;
    const url = `https://wa.me/5521982590643?text=${encodeURIComponent(mensagem)}`;
    window.open(url, '_blank');
    modal.style.display = 'none';
  });
</script>