---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Royal Splash — Piscinas de Alto Padrão</title>
    <meta name="description" content="Projetamos e construímos piscinas, saunas e áreas de lazer sob medida. Excelência em cada detalhe, do Rio de Janeiro a Santa Catarina." />
  </head>
  <body class="bg-slate-950 text-white">

    <Header />

    <!-- ===== HERO ===== -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden">

      <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-sky-950 to-slate-950"></div>

      <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
        <p class="text-sm md:text-base uppercase tracking-widest text-sky-400 mb-6">
          Piscinas de alto padrão · Rio de Janeiro e Santa Catarina
        </p>
        <h1 class="text-4xl md:text-6xl font-semibold leading-tight mb-6">
          Excelência em cada detalhe, do projeto à primeira mergulhada.
        </h1>
        <p class="text-lg md:text-xl text-slate-300 mb-10">
          Projetamos e construímos piscinas, saunas e áreas de lazer sob medida — com acabamento impecável e execução própria do início ao fim.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#contato" class="bg-sky-500 hover:bg-sky-400 text-white font-medium px-8 py-4 rounded-full transition-colors">
            Solicitar orçamento
          </a>
          <a href="#portfolio" class="border border-white/30 hover:border-white/60 text-white font-medium px-8 py-4 rounded-full transition-colors">
            Ver obras
          </a>
        </div>
      </div>
    </section>

    <!-- ===== SERVIÇOS ===== -->
    <section id="servicos" class="bg-slate-950 py-24 px-6 scroll-mt-20">
      <div class="max-w-6xl mx-auto">

        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-semibold mb-4">O que construímos</h2>
          <p class="text-lg text-slate-400 max-w-2xl mx-auto">
            Soluções completas para transformar seu espaço num refúgio de lazer.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          <div class="bg-slate-900 border border-white/10 rounded-2xl p-8 hover:border-sky-500/50 transition-colors">
            <h3 class="text-xl font-semibold mb-3">Construção de Piscinas</h3>
            <p class="text-slate-400">Alvenaria, borda infinita, prainha, iluminação LED e automação. Cada piscina sob medida para o seu espaço.</p>
          </div>
          <div class="bg-slate-900 border border-white/10 rounded-2xl p-8 hover:border-sky-500/50 transition-colors">
            <h3 class="text-xl font-semibold mb-3">Áreas de Lazer</h3>
            <p class="text-slate-400">Espaço gourmet, decks, paisagismo, iluminação e duchas. O ambiente inteiro pensado como uma experiência.</p>
          </div>
          <div class="bg-slate-900 border border-white/10 rounded-2xl p-8 hover:border-sky-500/50 transition-colors">
            <h3 class="text-xl font-semibold mb-3">Saunas & Spas</h3>
            <p class="text-slate-400">Saunas secas e úmidas, spas e ofurôs. Bem-estar com o acabamento Royal Splash.</p>
          </div>
          <div class="bg-slate-900 border border-white/10 rounded-2xl p-8 hover:border-sky-500/50 transition-colors">
            <h3 class="text-xl font-semibold mb-3">Reforma e Revitalização</h3>
            <p class="text-slate-400">Recuperação estrutural e estética da sua piscina, incluindo fibra. Devolvemos vida ao seu espaço.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PORTFÓLIO ===== -->
    <section id="portfolio" class="bg-slate-900 py-24 px-6 scroll-mt-20">
      <div class="max-w-6xl mx-auto">

        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-semibold mb-4">Obras que falam por si</h2>
          <p class="text-lg text-slate-400 max-w-2xl mx-auto">
            Conheça alguns dos projetos que já entregamos.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/10 group">
            <img src="/obras/obra-1.jpg" alt="Piscina de borda infinita Royal Splash" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/10 group">
            <img src="/obras/obra-2.jpg" alt="Piscina com iluminação LED Royal Splash" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/10 group">
            <img src="/obras/obra-3.jpg" alt="Área de lazer com piscina Royal Splash" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/10 group">
            <img src="/obras/obra-4.jpg" alt="Piscina com prainha Royal Splash" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/10 group">
            <img src="/obras/obra-5.jpg" alt="Spa e ofurô na serra Royal Splash" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/10 group">
            <img src="/obras/obra-6.jpg" alt="Vista de área de lazer residencial Royal Splash" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
        </div>
      </div>
    </section>

    <!-- ===== DIFERENCIAIS ===== -->
    <section class="bg-slate-950 py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-semibold mb-4">Por que Royal Splash</h2>
        </div>
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
          <div>
            <div class="text-sky-400 text-3xl font-bold mb-3">01</div>
            <h3 class="text-lg font-semibold mb-2">Projeto sob medida</h3>
            <p class="text-slate-400">Nada de solução pronta. Cada piscina nasce do seu espaço e do seu jeito de viver.</p>
          </div>
          <div>
            <div class="text-sky-400 text-3xl font-bold mb-3">02</div>
            <h3 class="text-lg font-semibold mb-2">Acabamento impecável</h3>
            <p class="text-slate-400">"Excelência em cada detalhe" não é slogan — é o nosso padrão de entrega.</p>
          </div>
          <div>
            <div class="text-sky-400 text-3xl font-bold mb-3">03</div>
            <h3 class="text-lg font-semibold mb-2">Execução própria</h3>
            <p class="text-slate-400">Do projeto à obra, uma equipe só. Não terceirizamos o que importa.</p>
          </div>
          <div>
            <div class="text-sky-400 text-3xl font-bold mb-3">04</div>
            <h3 class="text-lg font-semibold mb-2">Tecnologia e automação</h3>
            <p class="text-slate-400">Iluminação, aquecimento e controle da piscina na palma da mão.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== COMO FUNCIONA ===== -->
    <section class="bg-slate-900 py-24 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-semibold mb-4">Do sonho à primeira mergulhada</h2>
        </div>
        <div class="space-y-8">
          <div class="flex gap-6 items-start">
            <div class="shrink-0 w-12 h-12 rounded-full bg-sky-500 flex items-center justify-center font-semibold">1</div>
            <div>
              <h3 class="text-lg font-semibold mb-1">Conversa e projeto</h3>
              <p class="text-slate-400">Entendemos seu espaço, seu gosto e seu orçamento, e desenhamos a solução ideal.</p>
            </div>
          </div>
          <div class="flex gap-6 items-start">
            <div class="shrink-0 w-12 h-12 rounded-full bg-sky-500 flex items-center justify-center font-semibold">2</div>
            <div>
              <h3 class="text-lg font-semibold mb-1">Planejamento</h3>
              <p class="text-slate-400">Projeto detalhado, cronograma e transparência do começo ao fim.</p>
            </div>
          </div>
          <div class="flex gap-6 items-start">
            <div class="shrink-0 w-12 h-12 rounded-full bg-sky-500 flex items-center justify-center font-semibold">3</div>
            <div>
              <h3 class="text-lg font-semibold mb-1">Execução</h3>
              <p class="text-slate-400">Construímos com o padrão Royal Splash, no prazo combinado.</p>
            </div>
          </div>
          <div class="flex gap-6 items-start">
            <div class="shrink-0 w-12 h-12 rounded-full bg-sky-500 flex items-center justify-center font-semibold">4</div>
            <div>
              <h3 class="text-lg font-semibold mb-1">Entrega</h3>
              <p class="text-slate-400">Você recebe pronto para aproveitar — e seguimos por perto.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CONTATO ===== -->
    <section id="contato" class="bg-slate-950 py-24 px-6 scroll-mt-20">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl md:text-5xl font-semibold mb-4">Pronto para transformar seu espaço?</h2>
        <p class="text-lg text-slate-400 mb-10">
          Fale com a gente e receba um orçamento sem compromisso.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://wa.me/5521982590643" target="_blank" class="bg-sky-500 hover:bg-sky-400 text-white font-medium px-8 py-4 rounded-full transition-colors">
            Falar no WhatsApp
          </a>
          <a href="mailto:contato@royalsplash.com.br" class="border border-white/30 hover:border-white/60 text-white font-medium px-8 py-4 rounded-full transition-colors">
            Enviar e-mail
          </a>
          <a href="https://instagram.com/royalsplashoficial" target="_blank" class="border border-white/30 hover:border-white/60 text-white font-medium px-8 py-4 rounded-full transition-colors">
            Instagram
          </a>
        </div>
        <p class="text-slate-500 mt-8 text-sm">
          (21) 98259-0643 · contato@royalsplash.com.br
        </p>
      </div>
    </section>

    <Footer />

  </body>
</html>