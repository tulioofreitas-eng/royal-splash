---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BotaoWhatsapp from '../components/BotaoWhatsapp.astro';
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Recebemos sua solicitação — Royal Splash</title>
    <meta name="robots" content="noindex" />
  </head>
  <body class="bg-marca text-white pt-20">

    <Header />

    <section class="min-h-[70vh] flex items-center justify-center px-6 text-center">
      <div class="max-w-xl">
        <span class="text-6xl mb-6 block">✓</span>
        <h1 class="text-3xl md:text-5xl font-semibold mb-4">Recebemos sua solicitação!</h1>
        <p class="text-lg text-slate-400 mb-8">
          Obrigado pelo contato. Nossa equipe vai analisar os detalhes do seu projeto e retornar em breve pelo telefone ou e-mail informado.
        </p>
        <a href="https://wa.me/5521982590643" target="_blank" class="inline-block bg-piscina hover:opacity-90 text-white font-medium px-8 py-4 rounded-full transition-opacity mb-4">
          Falar agora pelo WhatsApp
        </a>
        <br />
        <a href="/" class="text-piscina hover:opacity-80 font-medium">← Voltar para o site</a>
      </div>
    </section>

    <Footer />
    <BotaoWhatsapp />
  </body>
</html>