---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Serviços Residenciais — Royal Splash</title>
    <meta name="description" content="Construção de piscinas, áreas de lazer, saunas, spas e reforma para sua casa. Serviços residenciais Royal Splash." />
  </head>
  <body class="bg-slate-950 text-white pt-20">

    <Header />

    <section class="pt-16 pb-16 px-6 text-center">
      <span class="text-sm uppercase tracking-widest text-sky-400">Para sua casa</span>
      <h1 class="text-4xl md:text-6xl font-semibold mt-3 mb-4">Serviços Residenciais</h1>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        Soluções completas para transformar o espaço da sua casa num refúgio de lazer de alto padrão.
      </p>
    </section>

    <!-- Residencial 1 -->
    <section class="py-12 px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div class="aspect-[4/3] rounded-2xl bg-slate-800 border border-white/10 flex items-center justify-center text-slate-500">
          Foto — Construção de Piscinas
        </div>
        <div>
          <h3 class="text-2xl md:text-3xl font-semibold mb-4">Construção de Piscinas Personalizadas</h3>
          <p class="text-slate-400 mb-6">Cada piscina nasce do seu espaço e do seu estilo de vida. Trabalhamos com alvenaria, borda infinita, prainha, iluminação LED e automação completa.</p>
          <a href="/#contato" class="text-sky-400 hover:text-sky-300 font-medium">Solicitar orçamento →</a>
        </div>
      </div>
    </section>

    <!-- Residencial 2 -->
    <section class="py-12 px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div class="aspect-[4/3] rounded-2xl bg-slate-800 border border-white/10 flex items-center justify-center text-slate-500 md:order-2">
          Foto — Áreas de Lazer
        </div>
        <div class="md:order-1">
          <h3 class="text-2xl md:text-3xl font-semibold mb-4">Áreas de Lazer Completas</h3>
          <p class="text-slate-400 mb-6">Espaço gourmet, decks, paisagismo, iluminação e duchas. Pensamos o ambiente inteiro como uma experiência, não só a piscina.</p>
          <a href="/#contato" class="text-sky-400 hover:text-sky-300 font-medium">Solicitar orçamento →</a>
        </div>
      </div>
    </section>

    <!-- Residencial 3 -->
    <section class="py-12 px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div class="aspect-[4/3] rounded-2xl bg-slate-800 border border-white/10 flex items-center justify-center text-slate-500">
          Foto — Saunas & Spas
        </div>
        <div>
          <h3 class="text-2xl md:text-3xl font-semibold mb-4">Saunas & Spas</h3>
          <p class="text-slate-400 mb-6">Saunas secas e úmidas, spas e ofurôs, com o acabamento e o padrão de bem-estar que definem a Royal Splash.</p>
          <a href="/#contato" class="text-sky-400 hover:text-sky-300 font-medium">Solicitar orçamento →</a>
        </div>
      </div>
    </section>

    <!-- Residencial 4 -->
    <section class="py-12 px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div class="aspect-[4/3] rounded-2xl bg-slate-800 border border-white/10 flex items-center justify-center text-slate-500 md:order-2">
          Foto — Reforma e Revitalização
        </div>
        <div class="md:order-1">
          <h3 class="text-2xl md:text-3xl font-semibold mb-4">Reforma e Revitalização</h3>
          <p class="text-slate-400 mb-6">Recuperação estrutural e estética da sua piscina, incluindo fibra. Devolvemos vida, segurança e beleza ao seu espaço.</p>
          <a href="/#contato" class="text-sky-400 hover:text-sky-300 font-medium">Solicitar orçamento →</a>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="py-24 px-6 text-center border-t border-white/10">
      <h2 class="text-3xl md:text-4xl font-semibold mb-4">Vamos tirar seu projeto do papel?</h2>
      <p class="text-slate-400 mb-8">Fale com a gente e receba um orçamento sem compromisso.</p>
      <a href="https://wa.me/5521982590643" target="_blank" class="inline-block bg-sky-500 hover:bg-sky-400 text-white font-medium px-8 py-4 rounded-full transition-colors">
        Falar no WhatsApp
      </a>
    </section>

    <Footer />

  </body>
</html>