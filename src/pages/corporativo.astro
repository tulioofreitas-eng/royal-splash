---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BotaoWhatsapp from '../components/BotaoWhatsapp.astro';
import { Image } from 'astro:assets';
import corpOlimpica from '../assets/corp-olimpica.jpg';
import corpHotel from '../assets/corp-hotel.jpg';
import corpRevestimento from '../assets/corp-revestimento.jpg';
import corpManutencao from '../assets/corp-manutencao.jpg';
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Soluções Corporativas — Royal Splash</title>
    <meta name="description" content="Piscinas olímpicas, áreas de lazer para hotéis e resorts, substituição submersa de revestimentos e manutenção expressa. Soluções corporativas Royal Splash." />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
  </head>
  <body class="bg-marca text-white pt-20">

    <Header />

    <section class="pt-16 pb-16 px-6 text-center">
      <span class="text-sm uppercase tracking-widest text-piscina">Para sua empresa</span>
      <h1 class="text-4xl md:text-6xl font-semibold mt-3 mb-4">Soluções Corporativas</h1>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        Excelência que sua empresa vê e seus clientes sentem. Soluções completas para clubes, hotéis, resorts, academias e condomínios de alto padrão.
      </p>
    </section>

    <section class="py-12 px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/10">
          <Image src={corpOlimpica} alt="Piscinas olímpicas e complexos aquáticos Royal Splash" class="w-full h-full object-cover" />
        </div>
        <div>
          <h3 class="text-2xl md:text-3xl font-semibold mb-4">Piscinas Olímpicas e Complexos Aquáticos</h3>
          <p class="text-slate-400 mb-6">Projetamos e executamos piscinas semiolímpicas, olímpicas e recreativas com precisão técnica e segurança normativa, para clubes, escolas, academias e centros esportivos — com infraestrutura profissional, acessibilidade e acabamentos para uso intenso.</p>
          <a href="/#contato" class="text-piscina hover:opacity-80 font-medium">Fale conosco →</a>
        </div>
      </div>
    </section>

    <section class="py-12 px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/10 md:order-2">
          <Image src={corpHotel} alt="Áreas de lazer para hotéis e resorts Royal Splash" class="w-full h-full object-cover" />
        </div>
        <div class="md:order-1">
          <h3 class="text-2xl md:text-3xl font-semibold mb-4">Áreas de Lazer para Hotéis e Resorts</h3>
          <p class="text-slate-400 mb-6">Transformamos ambientes externos em diferenciais de experiência para os hóspedes: piscinas sofisticadas, spas, saunas, decks, áreas molhadas, duchas e paisagismo integrado, com padrão internacional de acabamento.</p>
          <a href="/#contato" class="text-piscina hover:opacity-80 font-medium">Fale conosco →</a>
        </div>
      </div>
    </section>

    <section class="py-12 px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/10">
          <Image src={corpRevestimento} alt="Substituição submersa de revestimentos Royal Splash" class="w-full h-full object-cover" />
        </div>
        <div>
          <h3 class="text-2xl md:text-3xl font-semibold mb-4">Substituição Submersa de Revestimentos</h3>
          <p class="text-slate-400 mb-6">Troca de revestimentos com a piscina cheia, preservando a operação do espaço e evitando desperdício de água. Solução técnica avançada, ideal para hotéis, clubes e academias que não podem interromper suas atividades.</p>
          <a href="/#contato" class="text-piscina hover:opacity-80 font-medium">Fale conosco →</a>
        </div>
      </div>
    </section>

    <section class="py-12 px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-white/10 md:order-2">
          <Image src={corpManutencao} alt="Manutenção expressa de piscinas Royal Splash" class="w-full h-full object-cover" />
        </div>
        <div class="md:order-1">
          <h3 class="text-2xl md:text-3xl font-semibold mb-4">Manutenção Expressa</h3>
          <p class="text-slate-400 mb-6">Recuperação emergencial da qualidade da água para estabelecimentos que não podem parar. Técnicas avançadas, produtos específicos e monitoramento constante para água limpa, segura e cristalina em até 48 horas.</p>
          <a href="/#contato" class="text-piscina hover:opacity-80 font-medium">Fale conosco →</a>
        </div>
      </div>
    </section>

    <section class="py-24 px-6 text-center border-t border-white/10">
      <h2 class="text-3xl md:text-4xl font-semibold mb-4">Vamos elevar o padrão do seu negócio?</h2>
      <p class="text-slate-400 mb-8">Fale com nossa equipe e receba uma proposta sob medida.</p>
      <a href="https://wa.me/5521982590643" target="_blank" class="inline-block bg-piscina hover:opacity-90 text-white font-medium px-8 py-4 rounded-full transition-opacity">
        Falar no WhatsApp
      </a>
    </section>

    <Footer />
    <BotaoWhatsapp />

  </body>
</html>